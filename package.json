{
  "name": "react-chorus",
  "version": "0.0.1",
  "description": "Composable chat UI components for React.",
  "type": "module",
  "main": "./dist/react-chorus.cjs.js",
  "module": "./dist/react-chorus.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/react-chorus.es.js",
      "require": "./dist/react-chorus.cjs.js"
    },
    "./headless": {
      "types": "./dist/types/headless.d.ts",
      "import": "./dist/react-chorus-headless.es.js",
      "require": "./dist/react-chorus-headless.cjs.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dompurify": "^3.2.7",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.544.0",
    "marked": "^16.3.0",
    "marked-highlight": "^2.2.2"
  }
}
