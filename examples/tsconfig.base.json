// Shared TypeScript base for the examples. Each example extends this with its
// own tsconfig.json so `tsc --noEmit` and IDE typechecking work. The bundler
// (Vite, or Next for the with-next App Router example) still performs the
// actual transpile/build; this config is type-only (noEmit).
{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true
  }
}
